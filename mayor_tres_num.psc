Algoritmo mayor_menor
	definir num1,num2,num3 Como Real
	Escribir "ingrese 3 numeros y se le indicara cual es el mayor"
	leer num1
	leer num2
	leer num3
	si num1>num3 escribir "el numero ",num1," es el mayor"
	SiNo
		si num3>num2 escribir "el numero ",num3," es el mayor"
			sino escribir "el numero ",num2," es el mayor"
		FinSi
	FinSi
FinAlgoritmo

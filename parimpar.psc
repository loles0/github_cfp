Algoritmo pari_impar
	definir numb como entero
	Escribir "ingrese un numero y se le dira si es par o impar"
	leer numb
	si numb=0 entonces escribir "el numero es cero"
	sino
		si numb mod 2=1 escribir "el numero es impar"
		SiNo
			si numb mod 2=0 entonces escribir "el numero es par"
		FinSi
	finsi
FinSi

FinAlgoritmo

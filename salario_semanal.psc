Algoritmo salario_semanal
	Definir horas,vale,salario,dias como real
	escribir "ingrese cuantas horas de trabajo y el valor de cada una y se calculara su salario"
	Esperar 5 Segundos
	Borrar Pantalla
	escribir "ingrese cuantas horas por dia trabaja"
	leer horas
	escribir "ingrese el valor por hora"
	leer vale
	Escribir "ingrese cuantos dias por semana trabaja"
	leer dias
	salario=horas*vale*dias
	escribir "su salario es: ",salario
FinAlgoritmo
